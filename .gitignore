# ============================================================
# .gitignore — Uber Stock Analysis Project
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (keep raw; ignore large processed/cached)
data/processed/
data/cache/
*.csv.gz
*.parquet

# Models (large binaries — store with DVC or Git LFS)
models/*.pkl
models/*.joblib
models/*.json

# Outputs (regenerated by pipeline)
outputs/plots/
outputs/reports/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Environment variables
.env
.env.local

# Coverage / testing
.coverage
htmlcov/
.pytest_cache/
*.coveragerc

# Distribution
*.whl
*.tar.gz
